{
  "name": "smartkmark",
  "version": "1.0.0",
  "description": "Editor Markdown desktop com Electron + React + TypeScript",
  "main": "dist-electron/main.js",
  "author": "Rafael Ribeiro <ribeirorafaelmatheus@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rafaelmgr12/smartkmark.git"
  },
  "homepage": "https://github.com/rafaelmgr12/smartkmark",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "concurrently -k \"npm:dev:electron:tsc\" \"npm:dev:electron:run\"",
    "dev:electron:tsc": "tsc -p electron/tsconfig.json --watch",
    "dev:electron:run": "wait-on tcp:5173 dist-electron/main.js && nodemon --watch dist-electron --ext js --exec \"electron dist-electron/main.js\"",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "lint": "eslint src electron tests *.ts",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@codemirror/commands": "^6.9.1",
    "@codemirror/lang-markdown": "^6.3.4",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.6",
    "@uiw/react-codemirror": "^4.24.1",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.22",
    "lucide-react": "^1.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "uuid": "^13.0.0",
    "yauzl": "^3.3.0",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.0",
    "@eslint/js": "^9.24.0",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.24.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "nodemon": "^3.1.7",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.29.1",
    "vite": "^6.0.3",
    "vitest": "^3.1.1",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.smartkmark.app",
    "productName": "SmartKMark",
    "icon": "build/icon.png",
    "afterSign": "scripts/notarize.cjs",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    }
  }
}
